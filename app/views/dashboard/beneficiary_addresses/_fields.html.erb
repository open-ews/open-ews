<div class="card mb-3" data-controller="remove-nested-form">
  <div class="ribbon ribbon-top bg-red" data-bs-toggle="tooltip" data-bs-placement="top" title="Remove address">
    <i class="icon ti ti-trash cursor-pointer" data-action="click->remove-nested-form#remove"></i>
  </div>

  <div class="card-body">
    <%= form.input :_destroy, as: :hidden, input_html: { data: { "remove-nested-form-target": "destroyElement" } } %>

    <div class="row">
      <div class="col-md-6">
        <%= form.input(
          :iso_region_code,
          label:
            safe_join(
              [
                FieldDefinitions::BeneficiaryFields.find_by!(name: :iso_region_code).human_name(namespace: current_account.iso_country_code),
                link_to(
                  "https://en.wikipedia.org/wiki/ISO_3166-2:#{current_account.iso_country_code}",
                  target: "_blank",
                  rel: "noopener",
                  style: "text-decoration: none;",
                  aria: { label: "Help" }
                ) do
                  content_tag(:i, "", class: "ti ti-info-circle")
                end
              ], " "
            )
        ) %>
      </div>
    </div>

    <div class="row">
      <div class="col">
        <%= form.input(
          :administrative_division_level_2_code,
          label: FieldDefinitions::BeneficiaryFields.find_by!(name: :administrative_division_level_2_code).human_name(namespace: current_account.iso_country_code)
        ) %>
      </div>
      <div class="col">
        <%= form.input(
          :administrative_division_level_2_name,
          label: FieldDefinitions::BeneficiaryFields.find_by!(name: :administrative_division_level_2_name).human_name(namespace: current_account.iso_country_code)
        ) %>
      </div>
    </div>

    <div class="row">
      <div class="col">
        <%= form.input(
          :administrative_division_level_3_code,
          label: FieldDefinitions::BeneficiaryFields.find_by!(name: :administrative_division_level_3_code).human_name(namespace: current_account.iso_country_code)
        ) %>
      </div>
      <div class="col">
        <%= form.input(
          :administrative_division_level_3_name,
          label: FieldDefinitions::BeneficiaryFields.find_by!(name: :administrative_division_level_3_name).human_name(namespace: current_account.iso_country_code)
        ) %>
      </div>
    </div>

    <div class="row">
      <div class="col">
        <%= form.input(
          :administrative_division_level_4_code,
          label: FieldDefinitions::BeneficiaryFields.find_by!(name: :administrative_division_level_4_code).human_name(namespace: current_account.iso_country_code)
        ) %>
      </div>
      <div class="col">
        <%= form.input(
          :administrative_division_level_4_name,
          label: FieldDefinitions::BeneficiaryFields.find_by!(name: :administrative_division_level_4_name).human_name(namespace: current_account.iso_country_code)
        ) %>
      </div>
    </div>

    <div class="row">
      <div class="col">
        <%= form.input(
          :administrative_division_level_5_code,
          label: FieldDefinitions::BeneficiaryFields.find_by!(name: :administrative_division_level_5_code).human_name(namespace: current_account.iso_country_code)
        ) %>
      </div>
      <div class="col">
        <%= form.input(
          :administrative_division_level_5_name,
          label: FieldDefinitions::BeneficiaryFields.find_by!(name: :administrative_division_level_5_name).human_name(namespace: current_account.iso_country_code)
        ) %>
      </div>
    </div>
  </div>
</div>
